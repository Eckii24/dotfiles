{
  "lastChangelogVersion": "0.80.6",
  "defaultThinkingLevel": "medium",
  "defaultProvider": "github-copilot",
  "defaultModel": "claude-sonnet-5",
  "chatModel": "github-copilot/gpt-5.4-mini",
  "enableInstallTelemetry": false,
  "packages": [],
  "npmCommand": [
    "bun"
  ],
  "guardrails": {
    "timeout": 300000,
    "paths": {
      "denyRead": [
        "**/.env",
        "**/.env.*",
        "~/.ssh/**",
        "~/.gnupg/**",
        "~/.aws/**",
        "~/.config/gh/**",
        "~/.kube/**",
        "~/.pi/agent/auth.json",
        "~/.pi/agent/models.json",
        "**/.npmrc",
        "**/.pypirc",
        "**/.netrc",
        "**/*.pem",
        "**/*.key",
        "**/auth.json",
        "**/credentials.json",
        "**/secrets.json",
        "**/*secrets.zsh"
      ],
      "allowWrite": [
        "./**",
        "/tmp/**",
        "**/.ai/**",
        "~/.agents/**",
        "~/.pi/**"
      ],
      "denyWrite": [
        "**/.env",
        "**/.env.*",
        "**/.git/**",
        "**/node_modules/**",
        "~/.pi/agent/auth.json",
        "~/.pi/agent/models.json",
        "**/.npmrc",
        "**/.pypirc",
        "**/.netrc",
        "**/*.pem",
        "**/*.key",
        "**/auth.json",
        "**/credentials.json",
        "**/secrets.json"
      ]
    },
    "bash": {
      "allow": [
        "pwd",
        "which",
        "ls",
        "cat",
        "head",
        "tail",
        "wc",
        "nl",
        "grep",
        "sort",
        "uniq",
        "cut",
        "paste",
        "tr",
        "strings",
        "xxd",
        "hexdump",
        "od",
        "file",
        "stat",
        "sha256sum",
        "shasum",
        "diff"
      ],
      "preflightModel": "github-copilot/gpt-5.4-mini",
      "preflightRules": [
        "Executing local tests is fine, even if test code runs arbitrary project code, as long as it does not exfiltrate secrets or mutate unrelated system state."
      ],
      "deny": [
        "rm",
        "sudo",
        "chmod",
        "chown",
        "mkfs",
        "dd",
        "shutdown",
        "reboot",
        "poweroff",
        "halt",
        "kill",
        "killall",
        "pkill"
      ]
    }
  },
  "theme": "dark"
}