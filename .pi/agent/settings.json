{
  "lastChangelogVersion": "0.67.2",
  "defaultThinkingLevel": "high",
  "defaultProvider": "github-copilot",
  "defaultModel": "gpt-5.4",
  "enableInstallTelemetry": false,
  "packages": [],
  "guardrails": {
    "timeout": 300000,
    "paths": {
      "denyRead": [
        "**/.env",
        "**/.env.*",
        "~/.ssh/**",
        "~/.gnupg/**",
        "**/*.pem",
        "**/*.key",
        "**/credentials.json",
        "**/secrets.json",
        "**/*secrets.zsh"
      ],
      "allowWrite": [
        "./**",
        "/tmp/**",
        "**/.ai/**",
        "~/.agents/**",
        "~/.pi/**"
      ],
      "denyWrite": [
        "**/.env",
        "**/.env.*",
        "**/.git/**",
        "**/node_modules/**",
        "**/*.pem",
        "**/*.key"
      ]
    },
    "bash": {
      "allow": [
        "pwd",
        "which",
        "ls",
        "cat",
        "head",
        "tail",
        "wc",
        "nl",
        "grep",
        "sort",
        "uniq",
        "cut",
        "paste",
        "tr",
        "strings",
        "xxd",
        "hexdump",
        "od",
        "file",
        "stat",
        "sha256sum",
        "shasum",
        "diff"
      ],
      "preflightModel": "github-copilot/claude-haiku-4.5",
      "deny": [
        "rm",
        "sudo",
        "chmod",
        "chown",
        "mkfs",
        "dd",
        "shutdown",
        "reboot",
        "poweroff",
        "halt",
        "kill",
        "killall",
        "pkill"
      ]
    }
  }
}