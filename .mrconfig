[docker-container]
checkout = git clone 'git@gitlab.com:eckii24/docker-container.git' 'docker-container'

[.local/share/yadm/repo.git]
checkout = yadm clone 'git@github.com:Eckii24/dotfiles.git' --no-bootstrap
update = yadm pull "$@"
fetch = yadm fetch --all --prune --tags "$@"
status = yadm status -s "$@" || true; yadm --no-pager log --branches --not --remotes --simplify-by-decoration --decorate --oneline || true; yadm --no-pager stash list
commit = yadm commit -a "$@" && yadm push --all
record = yadm commit -a "$@"
push = yadm push "$@"
diff = yadm diff "$@"
log = yadm log "$@"
grep = yadm grep "$@"
clean = echo "Skipping clean: yadm disables git clean for safety"
